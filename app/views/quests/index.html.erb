<% content_for :title, t("app.browser_title") %>

<div class="min-h-screen bg-gray-950 text-gray-100 font-mono">

  <%# ── Header ── %>
  <header class="border-b border-cyan-800 px-6 py-4 flex items-center justify-between">
    <div>
      <span class="text-cyan-400 text-sm tracking-widest uppercase"><%= t("app.company") %></span>
      <h1 class="text-2xl font-bold text-white mt-1"><%= t("app.brand") %> <span class="text-cyan-400"><%= t("app.terminal") %></span></h1>
    </div>
    <div class="flex items-start gap-4">
      <div class="text-right text-xs text-gray-500">
        <div class="text-red-400 animate-pulse mt-1">⚠ <%= t("app.alert") %></div>
      </div>
      <%= render "shared/language_switcher" %>
    </div>
  </header>

  <%# ── Flash messages ── %>
  <% if notice %>
    <div class="mx-6 mt-4 px-4 py-3 bg-green-900/40 border border-green-500 text-green-300 rounded">
      <%= notice %>
    </div>
  <% end %>
  <% if alert %>
    <div class="mx-6 mt-4 px-4 py-3 bg-red-900/40 border border-red-500 text-red-300 rounded">
      <%= alert %>
    </div>
  <% end %>

  <%# ── Briefing ── %>
  <section class="px-6 py-6 border-b border-gray-800">
    <p class="text-gray-400 max-w-2xl leading-relaxed">
      <%= t("quests.index.intro_html") %>
    </p>
  </section>

  <%# ── Quest cards ── %>
  <main class="px-6 py-8 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
    <% @quests.each do |quest| %>
      <% meta = quest.locked? ? { module_name: "???", title: "????????", symptom: "????????????????" } : quest.meta %>
      <% results = @test_results[quest.quest_number.to_s] || {} %>

      <div class="rounded-lg border p-5 flex flex-col gap-4
        <%= quest.locked? ? 'border-gray-700 bg-gray-900/40 opacity-60' :
            quest.accepted? ? 'border-green-500 bg-green-900/20' :
            'border-cyan-600 bg-gray-900' %>">

        <%# ── Card header ── %>
        <div class="flex items-start justify-between gap-2">
          <div>
            <div class="text-xs tracking-widest text-gray-500 uppercase mb-1">
              <%= quest.locked? ? t("quests.index.redacted") : t("quests.index.module", number: quest.quest_number) %>
            </div>
            <div class="font-bold text-sm
              <%= quest.locked? ? 'text-gray-600' :
                  quest.accepted? ? 'text-green-400' : 'text-cyan-400' %>">
              <%= meta[:module_name] %>
            </div>
            <div class="text-white font-semibold mt-1"><%= meta[:title] %></div>
          </div>
          <div class="text-2xl shrink-0">
            <%= quest.locked?    ? '❔' :
                quest.accepted?  ? '✅' : '🔓' %>
          </div>
        </div>

        <%# ── Symptom ── %>
        <p class="text-xs text-gray-400 italic border-l-2 border-gray-700 pl-3">
          <%= meta[:symptom] %>
        </p>

        <%= render partial: "shared/test_badge", locals: {results: results} %>

        <%# ── Actions ── %>
        <div class="mt-auto flex gap-2 flex-wrap">
          <% if quest.locked? %>
            <span class="text-xs text-gray-600 italic"><%= t("quests.index.redacted_long") %></span>
          <% elsif quest.accepted? %>
            <span class="text-xs text-green-400 font-semibold"><%= t("quests.index.restored") %></span>
          <% else %>
            <%= link_to t("quests.index.open"),
              quest_path(quest.quest_number),
              class: "text-sm px-4 py-2 bg-cyan-700 hover:bg-cyan-600 text-white rounded transition font-semibold" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </main>

  <%# ── Footer ── %>
  <footer class="px-6 py-4 border-t border-gray-800 text-xs text-gray-600 flex justify-between">
    <span><%= t("app.footer") %></span>
  </footer>

</div>
