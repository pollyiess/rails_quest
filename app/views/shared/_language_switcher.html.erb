<div class="rounded-2xl border border-gray-800/80 bg-gray-950/80 p-1.5 shadow-lg shadow-black/30 backdrop-blur-sm">
  <div class="flex items-center gap-3 rounded-xl bg-black/20 px-2 py-1.5">
    <div class="hidden sm:flex items-center gap-2 pl-1 pr-2">
      <span class="text-md uppercase tracking-[0.35em] text-gray-500">
        <%= t("language_switcher.label") %>
      </span>
      <span class="h-1 w-1 rounded-full bg-cyan-400/80"></span>
    </div>

    <div class="flex items-center rounded-xl border border-gray-800 bg-gray-900/80 p-1">
      <% I18n.available_locales.each do |locale| %>
        <% active = I18n.locale == locale %>
        <%= button_to locale_path(locale: locale), method: :patch, form_class: "contents" do %>
          <span class="inline-flex min-w-16 items-center justify-center rounded-lg
                px-3 py-2 mx-2 text-xs font-semibold uppercase tracking-[0.25em] transition
                <%= active ? "bg-cyan-500 text-gray-950 shadow-[0_0_24px_rgba(34,211,238,0.35)]" : "text-gray-400 hover:bg-gray-800 hover:text-cyan-200" %>">
            <%= t("locales.#{locale}") %>
          </span>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
